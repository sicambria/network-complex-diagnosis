#!/bin/bash
# Pre-commit hook: sensitive-data scan + syntax check.
set -e

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'
BLOCKED=0

SENSITIVE_PATTERNS=(
    '/home/arsvivendi'
    '/Users/arsvivendi'
    "C:\\\\Users\\\\arsvivendi"
    'venividivici'
    'gho_'
    'ghp_'
    'ghs_'
    'sk-'
    'xoxp-'
    'xoxb-'
    'AKIA'
)

while IFS= read -r -d '' file; do
    if [ ! -f "$file" ]; then
        continue
    fi
    # Skip files that legitimately CATALOG the sensitive patterns as their
    # subject matter: the hooks (detection logic) and the two guide docs whose
    # "Git Guardrails" sections list the very patterns (gho_/ghp_/AKIA/hostname).
    # Without this exemption these files can never be committed once the hooks
    # are active, which only trains people to habitually --no-verify (worse).
    case "$file" in
        .githooks/*|AGENTS.md|CLAUDE.md) continue ;;
    esac
    for pattern in "${SENSITIVE_PATTERNS[@]}"; do
        if git show ":$file" 2>/dev/null | grep -q "$pattern"; then
            echo -e "${RED}[BLOCKED]${NC} $file contains sensitive pattern: $pattern"
            BLOCKED=1
        fi
    done
done < <(git diff --cached --name-only -z)

echo -e "${YELLOW}[PRE-COMMIT] Running syntax check...${NC}"
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$SCRIPT_DIR"

python3 -c "
import py_compile
import sys
try:
    py_compile.compile('netdiag.py', doraise=True)
    print('  [OK] netdiag.py syntax')
except py_compile.PyCompileError as e:
    print(f'  [FAIL] netdiag.py: {e}')
    sys.exit(1)
" || BLOCKED=1

if [ "$BLOCKED" -eq 1 ]; then
    echo -e "${RED}Commit rejected. Fix errors and try again.${NC}"
    exit 1
fi

echo -e "\e[32m[PRE-COMMIT] OK.\e[0m"
